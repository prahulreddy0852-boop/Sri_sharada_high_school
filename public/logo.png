<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Outer circle -->
  <circle cx="100" cy="100" r="95" fill="#a6a7a7" stroke="#D4A52E" stroke-width="4"/>
  
  <!-- Inner circle -->
  <circle cx="100" cy="100" r="85" fill="#FFFBF0"/>
  
  <!-- Decorative gold ring -->
  <circle cx="100" cy="100" r="80" fill="none" stroke="#D4A52E" stroke-width="2" opacity="0.6"/>
  
  <!-- Simplified Saraswati representation -->
  <g transform="translate(100, 70)">
    <!-- Head circle -->
    <circle cx="0" cy="0" r="18" fill="#F4C4A0"/>
    
    <!-- Crown/halo -->
    <path d="M -15 -18 Q 0 -25 15 -18" fill="none" stroke="#D4A52E" stroke-width="2.5" opacity="0.8"/>
    <circle cx="-12" cy="-20" r="2.5" fill="#D4A52E"/>
    <circle cx="0" cy="-24" r="3" fill="#D4A52E"/>
    <circle cx="12" cy="-20" r="2.5" fill="#D4A52E"/>
    
    <!-- Face outline -->
    <ellipse cx="0" cy="0" rx="16" ry="17" fill="none" stroke="#D4A52E" stroke-width="1" opacity="0.4"/>
  </g>
  
  <!-- Veena (musical instrument) representation -->
  <g transform="translate(75, 85)">
    <!-- Veena neck -->
    <line x1="8" y1="0" x2="35" y2="-15" stroke="#8B5A2B" stroke-width="3" stroke-linecap="round"/>
    <!-- Veena body -->
    <ellipse cx="15" cy="8" rx="12" ry="9" fill="#8B5A2B" opacity="0.8"/>
    <ellipse cx="15" cy="8" rx="10" ry="7" fill="#A0522D" opacity="0.6"/>
    <!-- Strings -->
    <line x1="15" y1="1" x2="35" y2="-15" stroke="#D4A52E" stroke-width="1.5" opacity="0.7"/>
    <line x1="15" y1="5" x2="35" y2="-15" stroke="#D4A52E" stroke-width="1.5" opacity="0.7"/>
  </g>
  
  <!-- Gold stars on sides -->
  <g fill="#D4A52E">
    <!-- Left star -->
    <path d="M 25 100 L 30 110 L 40 110 L 32 116 L 36 126 L 25 120 L 14 126 L 18 116 L 10 110 L 20 110 Z"/>
    <!-- Right star -->
    <path d="M 175 100 L 180 110 L 190 110 L 182 116 L 186 126 L 175 120 L 164 126 L 168 116 L 160 110 L 170 110 Z"/>
  </g>
  
  <!-- Lotus petals bottom -->
  <g fill="#F4C4A0" opacity="0.6" transform="translate(100, 135)">
    <ellipse cx="-12" cy="0" rx="6" ry="10" transform="rotate(-30 -12 0)"/>
    <ellipse cx="12" cy="0" rx="6" ry="10" transform="rotate(30 12 0)"/>
    <ellipse cx="0" cy="12" rx="6" ry="10"/>
  </g>
  
  <!-- Text wrapper (text is optional for small size) -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="#D4A52E" stroke-width="1" opacity="0.3"/>
</svg>